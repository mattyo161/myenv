eval "$($HOME/.local/bin/mise activate zsh)"

aws_completer="$(which aws_completer)"
if [[ -n "${aws_completer}" ]]; then
  autoload bashcompinit && bashcompinit
  autoload -Uz compinit && compinit
  complete -C "${aws_completer}" aws
fi

export KUBECONFIG="$HOME/.kube/config"
source <(kubectl completion zsh)
source <(talosctl completion zsh)

# Google Cloud SDK (gcloud/gsutil/bq) — PATH and completion
if [[ -f "/opt/homebrew/share/google-cloud-sdk/path.zsh.inc" ]]; then
  source "/opt/homebrew/share/google-cloud-sdk/path.zsh.inc"
  source "/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc"
fi

# Azure CLI (az) — completion
if [[ -f "/opt/homebrew/etc/bash_completion.d/az" ]]; then
  autoload -Uz bashcompinit && bashcompinit
  source "/opt/homebrew/etc/bash_completion.d/az"
fi

eval "$(starship init zsh)"

## DevOps Helpers
alias k=kubectl

alias tf=terraform
alias tfinit="terraform init"
alias tfplan="terraform plan"
alias tfapply="terraform apply"

# Machine-local overrides — NOT managed by chezmoi, so they're never overwritten
# by `chezmoi apply`. Put per-machine aliases/exports/secrets in ~/.zshrc.local.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

