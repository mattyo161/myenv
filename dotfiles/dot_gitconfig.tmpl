[user]
	name = {{ .name }}
	email = {{ .email }}
# Rewrites all GitHub HTTPS URLs to SSH so `git clone https://github.com/...`
# uses your SSH key automatically. Requires an SSH key added to your GitHub
# account. On a fresh machine without SSH keys this breaks `brew update` —
# see docs/runbooks.md "brew update fails with Host key verification failed".
[url "git@github.com:"]
  insteadOf = https://github.com/

[init]
	defaultBranch = main
